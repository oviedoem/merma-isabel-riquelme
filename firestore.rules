rules_version = '2';

// Proyecto isabel-riquelme-merma — independiente del Firestore de ferreteria-oviedo.
// Regla unica: solo usuarios autenticados (el unico usuario es 'riquelme') pueden
// leer/escribir. Sin autenticacion, acceso totalmente denegado.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
